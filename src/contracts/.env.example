# ──────────────────────────────────────────────────────────────
# HSMC — Smart Contract Deployment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# ── Deployer Wallet ─────────────────────────────────────────
# Private key of the deployer account (without 0x prefix)
PRIVATE_KEY=your_private_key_here_without_0x

# Mnemonic phrase (alternative to PRIVATE_KEY)
MNEMONIC="your twelve word mnemonic phrase here"

# ── RPC URLs ──────────────────────────────────────────────
# Primary RPC endpoints for each target chain
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Fallback public RPCs (used when primary is down)
ETHEREUM_FALLBACK_RPC=https://eth.drpc.org
ARBITRUM_FALLBACK_RPC=https://arb1.arbitrum.io/rpc
POLYGON_FALLBACK_RPC=https://polygon-rpc.com
BASE_FALLBACK_RPC=https://mainnet.base.org
OPTIMISM_FALLBACK_RPC=https://mainnet.optimism.io

# ── Etherscan API Keys (for contract verification) ──────────
ETHERSCAN_API_KEY=your_etherscan_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
OPTIMISTIC_ETHERSCAN_API_KEY=your_optimistic_etherscan_api_key

# ── Contract Constructor Arguments ──────────────────────────
# FlashLoanArbitrage: initial owner address + min profit threshold (in wei)
FLASH_LOAN_OWNER=0xYourOwnerAddressHere
FLASH_LOAN_MIN_PROFIT=1000000000000000000  # 1 ETH in wei (18 decimals)

# CrossChainArbitrage: initial owner
CROSS_CHAIN_OWNER=0xYourOwnerAddressHere

# YieldOptimizer: initial owner
YIELD_OPTIMIZER_OWNER=0xYourOwnerAddressHere

# ── Gas Configuration ─────────────────────────────────────
GAS_PRICE_GWEI=auto           # "auto" or specific number
GAS_LIMIT=3000000
PRIORITY_FEE_GWEI=2

# ── Deployment Mode ────────────────────────────────────────
# "mainnet" | "testnet" | "fork"
DEPLOYMENT_MODE=mainnet

# For fork mode — block number to fork from
FORK_BLOCK_NUMBER=latest

# ── Optional: Deploy single contract only ──────────────────
# Leave blank to deploy all. Set to one of:
# "FlashLoanArbitrage" | "CrossChainArbitrage" | "YieldOptimizer"
DEPLOY_SINGLE_CONTRACT=
